# ======================================
# portal_utils 环境变量配置
# ======================================
# 复制此文件为 .env 并填入真实值
#
# cp .env.example .env
# export $(cat .env | xargs)

# 登录凭证
PORTAL_EMAIL=xiaofei.zhao@unitpulse.ai
PORTAL_PASSWORD=changeme

# 目标 URL
PORTAL_URL=https://portal-dev.unitpulse.ai/messages/prospects

# 浏览器模式：true=无头, false=有头
HEADLESS=true

# 登录超时（秒）
LOGIN_TIMEOUT=60

# Node.js 路径覆盖（通常无需设置，自动发现）
# NODE_PATH=D:/node.js/node.exe
# PLAYWRIGHT_CLI_PATH=C:/Users/xuqin/AppData/Roaming/npm/node_modules/@playwright/cli/playwright-cli.js
